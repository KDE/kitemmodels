include($KDE_DOCS/global/qt-module-defaults-online.qdocconf)

project = KItemModelsQml
description = Models for Qt Model/View system.

documentationinheaders = true

headerdirs = .
sourcedirs = .

headers.fileextensions = "*.h"
sources.fileextensions = "*.qml *.qdoc"

outputformats = HTML

depends += \
    kde \
    qtcore \
    qtqml \
    qtquickcontrols \
    kitemmodels
